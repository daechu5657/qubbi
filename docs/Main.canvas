		{"id":"9e2ada353a085d22","type":"text","text":"# ***ComponentStyleModel***\n\n\tid: string\n\tcomponentVariantId: string | null\n\tlabel: string\n\tcssProperty: keyof ElementCSSInlineStyle[\"style\"]\n\tvalueKind: StyleValueKind\n\tstringValue: string | null;\n\tnumberValue: number | null;\n\tbooleanValue: boolean | null;\n\tunit: StyleValueUnit | null;\n\tformat: StyleValueFormat | null;\n","x":6620,"y":2020,"width":760,"height":440},
