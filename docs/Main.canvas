		{"id":"36a62299d694dd16","type":"text","text":"# ***PageModel***\n\n\tid: string\n\tstableId: string\n\tspaceId: string\n\tname: string\n\torder: number\n\trootPageTree: PageTreeModel | null\n","x":3000,"y":-140,"width":540,"height":280},
		{"id":"91da408d16f60431","type":"text","text":"# ***PageTreeModel***\n\n\tid: string\n\tstableId: string\n\tpageId: string\n\tcomponentId: string\n\tcomponentVariantId: string | null\n\tparentId: string | null\n\torder: number\n\tstyleOverrides: PageTreeStyleOverrideModel[];\n\tchildren: PageTreeModel[]\n","x":3000,"y":220,"width":540,"height":320},
