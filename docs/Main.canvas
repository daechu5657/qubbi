		{"id":"f34db1d8012c2666","type":"text","text":"# ***ProjectModel***\n\n\tid: string\n\tcurrentRevisionId: string\n\tname: string\n\tdescription: string\n\trevision: RevisionModel\n\tspaces: SpaceModel[]\n\tcomponentPresets: ProjectComponentPresetModel[]\n","x":2320,"y":-920,"width":540,"height":280},
