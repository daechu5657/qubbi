		{"id":"8f35e5b9923c2420","type":"text","text":"# ***Project***\n\n\t_id: ObjectId\n\tprojectGroupId: ObjectId\n\tcurrentRevisionId: ObjectId\n\tcreatedBy: ObjectId\n\tdescription: string\n","x":4040,"y":3960,"width":540,"height":280},
		{"id":"67e4f6d080ed0315","type":"text","text":"# ***PageTree***\n\n\t_id: ObjectId\n\tstableId: ObjectId (식별)\n\trevisionId: ObjectId\n\tpageId: ObjectId\n\tcomponentId: ObjectId\n\tcomponentVarinatId: ObjectId\n\tparentId: ObjectId | null\n\tchildrenIds: ObjectId[]\n\torder: number\n\t**propsOverride: ComponentManifestProps[] (인스턴스 delta)`**","x":4040,"y":5580,"width":540,"height":382},
