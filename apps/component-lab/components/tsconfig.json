{
  "extends": "../tsconfig.app.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "allowImportingTsExtensions": false,
    "sourceMap": false,
    "declarationMap": false
  },
  "include": ["./**/*.ts", "./**/*.tsx"],
  "exclude": ["./dist"]
}
